<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/gray_50">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_orange_blue"
        android:orientation="vertical" android:paddingHorizontal="20dp"
        android:paddingTop="48dp" android:paddingBottom="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="My Bookings 📋" android:textColor="@color/white"
            android:textSize="24sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="All your past and upcoming trips" android:textColor="#FFFFFFBB"
            android:textSize="13sp" android:layout_marginBottom="16dp"/>
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_booking_status"
            android:layout_width="match_parent" android:layout_height="40dp"
            android:background="@color/transparent"
            app:tabSelectedTextColor="@color/white"
            app:tabTextColor="#FFFFFF88"
            app:tabIndicatorColor="@color/white"
            app:tabIndicatorHeight="2dp"
            app:tabRippleColor="@color/transparent"
            app:tabMode="scrollable"
            />
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_bookings"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"/>
</LinearLayout>
