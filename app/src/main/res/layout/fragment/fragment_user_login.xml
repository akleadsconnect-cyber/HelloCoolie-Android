<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back 👋"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/gray_900"
            android:fontFamily="@font/nunito_bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in as Passenger"
            android:textSize="14sp"
            android:textColor="@color/gray_500"
            android:layout_marginBottom="28dp"/>

        <!-- Phone Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MOBILE NUMBER"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/gray_700"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            style="@style/Widget.HelloCoolie.TextInput"
            app:startIconDrawable="@drawable/ic_phone"
            app:startIconTint="@color/gray_400"
            app:boxStrokeColor="@color/hc_orange"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_phone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="phone"
                android:maxLength="10"
                android:hint="Enter 10-digit number"
                android:textSize="16sp"
                android:textColor="@color/gray_900"
                android:background="@null"
                android:paddingStart="4dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/gray_700"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            style="@style/Widget.HelloCoolie.TextInput"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="@color/gray_400"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/gray_400"
            app:boxStrokeColor="@color/hc_orange"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="textPassword"
                android:hint="Your password"
                android:textSize="16sp"
                android:textColor="@color/gray_900"
                android:background="@null"
                android:paddingStart="4dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Forgot password -->
        <TextView
            android:id="@+id/tv_forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="Forgot Password?"
            android:textColor="@color/hc_orange"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="28dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Sign in as Passenger →"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/nunito_bold"
            android:background="@drawable/ripple_orange"
            android:stateListAnimator="@null"
            android:elevation="6dp"
            android:layout_marginBottom="24dp"/>

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/gray_200"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="  OR  " android:textColor="@color/gray_400" android:textSize="12sp"/>
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/gray_200"/>
        </LinearLayout>

        <!-- Register Link -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New to HelloCoolie? "
                android:textColor="@color/gray_500"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_register"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Register"
                android:textColor="@color/hc_blue"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
